# ============================================================================
# Alison Haire personal site — environment variables
#
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. NEVER commit real keys.
#
# Production secrets live in Cloudflare Pages dashboard:
#   Workers & Pages → your project → Settings → Environment variables
# ============================================================================

# ---------------------------------------------------------------------------
# BUILD-TIME (used by `astro build` / `pnpm build`)
# ---------------------------------------------------------------------------

# Ghost blog Content API. Create read-only key at:
#   blog.alisonhaire.com/ghost → Integrations → Add custom integration
GHOST_URL=https://blog.alisonhaire.com
GHOST_CONTENT_API_KEY=

# YouTube Data API v3 (for /speaking auto-fetched talks).
# Create at https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=@DeveloperAlly

# ---------------------------------------------------------------------------
# RUNTIME (Cloudflare Pages Functions — set in CF dashboard for production)
# ---------------------------------------------------------------------------

# OpenRouter for Ally assistant. Free models available.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free

# Rate-limit knobs for /api/ally (per IP per UTC day).
ALLY_RATE_LIMIT_PER_DAY=20
ALLY_MAX_INPUT_CHARS=600

# /api/ingest authentication.
# Generate with: openssl rand -hex 32
INGEST_SHARED_SECRET=

# Optional: where /api/ingest forwards docs after auth check.
# Leave empty to disable the ingest endpoint entirely.
# Typically points to a Supabase Edge Function or n8n webhook.
INGEST_FORWARD_URL=

# ---------------------------------------------------------------------------
# USED BY N8N WORKFLOWS (not loaded by this app — listed for reference)
# ---------------------------------------------------------------------------
# Store these in n8n's credentials store, not in this .env.
#
# CF_DEPLOY_HOOK_URL=    Trigger CF Pages rebuild after content changes
# GITHUB_PAT_FOR_N8N=    Lets n8n commit JSON content updates to this repo
