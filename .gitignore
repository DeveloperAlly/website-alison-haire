# ============================================================================
# SECRETS — NEVER COMMIT
# ============================================================================
# Block every .env variant. .env.example is allow-listed below.
.env
.env.*
!.env.example

# Common secret file names
*.pem
*.key
*.p12
secrets.json
credentials.json
.netrc

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
.pnpm-store/
.npm/
.yarn/

# ============================================================================
# Build output
# ============================================================================
dist/
.astro/
.output/
.wrangler/
.vercel/
.netlify/

# ============================================================================
# OS / Editor
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
*.swp
*.swo

# ============================================================================
# Logs and temp
# ============================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
.cache/
.tmp/
tmp/

# ============================================================================
# Large binaries (lesson learned: 270MB JSON exports + zip archives)
# ============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ============================================================================
# Cloudflare Pages / Functions local state
# ============================================================================
.wrangler/
worker-configuration.d.ts

# ============================================================================
# Test / coverage
# ============================================================================
coverage/
.nyc_output/
*.lcov
